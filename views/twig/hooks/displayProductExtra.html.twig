<link rel="stylesheet" href="{{ asset('js/bs-table/bootstrap-table.min.css') }}">
<link rel="stylesheet" href="{{ asset('css/chosen/component-chosen.min.css') }}">
<link rel="stylesheet" href="{{ asset('css/style.css') }}">

<section class="table-list mt-4">
    <form id="formStockService" method="post">
        <div class="{% if controller=='AdminProducts' %}card{% else %}panel{% endif %}">
            <div class="{% if controller=='AdminProducts' %}card-header{% else %}panel-heading{% endif %}">
                <div class="d-flex align-items-center justify-content-between gap-2">
                    <div class="title">
                        <span class="material-icons mr-2">shopping_cart</span>
                        <span>STOCK SERVICE</span>
                    </div>
                </div>
            </div>
            <div class="{% if controller=='AdminProducts' %}card-body{% else %}panel-body{% endif %}">
                <div id="table-toolbar" class="d-flex justify-content-between align-items-center gap-4 mb-4">
                    <div class="card" style="width: 100%">
                        <div class="card-body d-flex justify-content-start align-items-center gap-4">
                            <div class="form-group mr-4">
                                <label>Attivare il servizio Stock Service?</label>
                                <div class="ps-switch ps-switch-lg ps-togglable-row">
                                    <input type="radio" name="switchStockServiceOnOff" id="switchStockServiceOnOff_off" value="0" {%if isStockService == 0%}checked{%endif%}>
                                    <label for="switchStockServiceOnOff_off">
                                        <span class="material-icons text-danger">close</span>
                                    </label>
                                    <input type="radio" name="switchStockServiceOnOff" id="switchStockServiceOnOff_on" value="1" {%if isStockService == 1%}checked{%endif%}>
                                    <label for="switchStockServiceOnOff_on">
                                        <span class="material-icons text-success">check</span>
                                    </label>
                                    <span class="slide-button"></span>
                                </div>
                            </div>
                            <div class="form-group mr-4">
                                <label>Forzare l'inserimento di tutti i dati stock-service?</label>
                                <div class="ps-switch ps-switch-lg ps-togglable-row">
                                    <input type="radio" name="switchStockServiceForceImport" id="switchStockServiceForceImport_off" value="0" checked>
                                    <label for="switchStockServiceForceImport_off">
                                        <span class="material-icons text-danger">close</span>
                                    </label>
                                    <input type="radio" name="switchStockServiceForceImport" id="switchStockServiceForceImport_on" value="1">
                                    <label for="switchStockServiceForceImport_on">
                                        <span class="material-icons text-success">check</span>
                                    </label>
                                    <span class="slide-button"></span>
                                </div>
                            </div>
                            <div class="form-group d-grow" id="requesterContainer">
                                <!-- div dinamico -->
                            </div>
                        </div>
                    </div>
                </div>
                <table id="table-list-stock-service" class="table table-striped table-condensed table-bordered"></table>
            </div>
            <div class="{% if controller=='AdminProducts' %}card-footer{% else %}panel-footer{% endif %}">
                <div class="d-flex justify-content-end align-items-center">
                    <button type="button" class="btn btn-primary" id="mpstockserviceBtnSaveStockService">
                        <span class="material-icons mr-2">save</span>
                        <span>Salva</span>
                    </button>
                </div>
            </div>
        </div>
    </form>
</section>

<script src="{{ asset('js/parseFile.js') }}"></script>
<script src="{{ asset('js/fetch.js') }}"></script>
<script src="{{ asset('js/ConfirmClass.js') }}"></script>
<script src="{{ asset('js/formatterQuantity.js') }}"></script>
<script src="{{ asset('js/formatterEan13.js') }}"></script>
<script src="{{ asset('js/bs-table/bootstrap-table.min.js') }}"></script>
<script src="{{ asset('js/bs-table/locale/bootstrap-table-it-IT.min.js') }}"></script>
<script src="{{ asset('js/callback.js') }}"></script>
<script src="{{ asset('js/displayProductExtra.js') }}"></script>
<script src="{{ asset('js/importResults.js') }}"></script>
<script src="{{ asset('js/BindStockServiceBsTable.js') }}"></script>
<script src="{{ asset('js/BindStockServiceEventsDelegation.js') }}"></script>
<script src="{{ asset('js/Requester.js') }}"></script>

<script type="text/javascript">
    const adminControllerUrl = "{{ adminControllerUrl|raw }}";
    const tableStockServiceId = "table-list-stock-service";
    const table = document.getElementById(tableStockServiceId);
    const mpstockserviceProductId = {{ id_product }};
    const uniqueId = "id_product";
    const mpstockserviceSuppliers = {{ suppliers|raw }};
    const mpstockserviceCombinations = {{ combinations|raw }};
    const isStockService = {{ isStockService }};
    
    let mpstockserviceBind = null;

    document.addEventListener('DOMContentLoaded', function() {
        console.log('DOMContentLoaded: displayProductExtra.html.twig');
        const requester = new Requester(adminControllerUrl, "requesterContainer", "{% if controller=='AdminProducts' %}0{% else %}1{% endif %}");
        requester.render();
        mpstockserviceBind = new BindStockServiceEventsDelegation(adminControllerUrl, mpstockserviceProductId);
    });    
</script>

