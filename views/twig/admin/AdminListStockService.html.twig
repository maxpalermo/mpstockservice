<script type="text/javascript">
    const adminControllerUrl = '{{ adminControllerUrl | raw }}';

    let adminProductUrl;
    let importPanelContainer;

    document.addEventListener('DOMContentLoaded', function() {
        console.log('DOMContentLoaded: AdminListStockService.js');
        adminProductUrl = "{{ adminProductUrl }}";
        importPanelContainer = document.getElementById("import-panel").querySelector("#import-panel-container");
        //Init Table
        initAdminStockServiceTable();
        
        //Render File selector
        const formImport = mpStockServiceRenderFileInput(true);
        importPanelContainer.append(formImport);

        //Bind Actions
        bindRenderFileInputActions(adminControllerUrl);
    });    
</script>